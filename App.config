<?xml version="1.0" encoding="utf-8" ?>
<configuration>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <connectionStrings>
    <add name="ITAssetManagementDB"
         connectionString="Server=.\SQLEXPRESS;Database=ITAssetManagementDB;Integrated Security=True;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="AppVersion" value="1.0.0" />
    <add key="AppName" value="IT Asset and Vulnerability Management System" />
  </appSettings>

</configuration>
